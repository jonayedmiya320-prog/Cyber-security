<%- include('partials/header', { pageTitle: 'লগইন' }) %>

<section class="auth-section">
  <div class="auth-card">
    <div class="auth-header">
      <h2><i class="fas fa-sign-in-alt"></i> লগইন</h2>
      <p><%= settings.siteName || 'MYMENSINGH CYBER LAB' %></p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>

    <form method="POST" action="/auth/login" class="auth-form">
      <div class="form-group">
        <label>ইমেইল</label>
        <input type="email" name="email" placeholder="আপনার ইমেইল" required class="form-input">
      </div>
      <div class="form-group">
        <label>পাসওয়ার্ড</label>
        <div class="input-eye-wrap">
          <input type="password" name="password" id="loginPassword" placeholder="পাসওয়ার্ড" required class="form-input">
          <button type="button" class="eye-btn" onclick="togglePassword('loginPassword')"><i class="fas fa-eye"></i></button>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">লগইন করুন</button>
    </form>

    <div class="auth-footer">
      <p>অ্যাকাউন্ট নেই? <a href="/auth/register">রেজিস্টার করুন</a></p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
