<%- include('partials/header', { pageTitle: 'লাইভ সাপোর্ট' }) %>

<section class="section">
  <div class="container">
    <h1 class="page-title"><i class="fas fa-headset"></i> লাইভ সাপোর্ট</h1>

    <div class="chat-wrapper">
      <div class="chat-box" id="chatBox">
        <div class="chat-messages" id="chatMessages">
          <div class="chat-welcome">
            <i class="fas fa-headset"></i>
            <p>স্বাগতম! আমরা সাহায্য করতে প্রস্তুত।</p>
          </div>
        </div>
        <div class="chat-input-area">
          <input type="text" id="chatInput" placeholder="আপনার বার্তা লিখুন..." class="chat-input">
          <button onclick="sendMessage()" class="btn btn-primary">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
const userId = '<%= user.id %>';
const userName = '<%= user.name %>';

socket.emit('joinRoom', { userId, userName, isAdmin: false });

socket.on('loadMessages', (messages) => {
  messages.forEach(msg => addMessage(msg));
});

socket.on('newMessage', (msg) => {
  addMessage(msg);
});

function addMessage(msg) {
  const div = document.createElement('div');
  div.className = 'chat-msg ' + (msg.from === 'user' ? 'chat-msg-user' : 'chat-msg-admin');
  div.innerHTML = `
    <div class="chat-bubble">
      <p>${msg.message}</p>
      <span class="chat-time">${msg.time}</span>
    </div>
  `;
  document.getElementById('chatMessages').appendChild(div);
  document.getElementById('chatMessages').scrollTop = 99999;
}

function sendMessage() {
  const input = document.getElementById('chatInput');
  const message = input.value.trim();
  if (!message) return;
  socket.emit('userMessage', { userId, userName, message });
  input.value = '';
}

document.getElementById('chatInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') sendMessage();
});
</script>

<%- include('partials/footer') %>