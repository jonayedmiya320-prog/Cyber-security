<%- include('partials/header', { pageTitle: 'ড্যাশবোর্ড' }) %>

<section class="section">
  <div class="container">
    <h1 class="page-title">স্বাগতম, <%= user.name %>!</h1>

    <div class="stats-grid">
      <div class="stat-card stat-blue">
        <i class="fas fa-clock"></i>
        <div>
          <h3><%= pending %></h3>
          <p>অপেক্ষমান অর্ডার</p>
        </div>
      </div>
      <div class="stat-card stat-green">
        <i class="fas fa-check-circle"></i>
        <div>
          <h3><%= approved %></h3>
          <p>অ্যাপ্রুভড অর্ডার</p>
        </div>
      </div>
      <div class="stat-card stat-red">
        <i class="fas fa-times-circle"></i>
        <div>
          <h3><%= rejected %></h3>
          <p>বাতিল অর্ডার</p>
        </div>
      </div>
    </div>

    <div class="dashboard-actions">
      <a href="/products" class="btn btn-primary"><i class="fas fa-shopping-bag"></i> কেনাকাটা করুন</a>
      <a href="/dashboard/orders" class="btn btn-outline"><i class="fas fa-list"></i> সব অর্ডার</a>
      <a href="/cart" class="btn btn-outline"><i class="fas fa-cart-shopping"></i> কার্ট</a>
    </div>

    <h2 class="section-title" style="margin-top:2rem;">সাম্প্রতিক অর্ডার</h2>

    <% if (orders.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-shopping-bag"></i>
        <p>এখনো কোনো অর্ডার নেই</p>
        <a href="/products" class="btn btn-primary">এখনই কিনুন</a>
      </div>
    <% } else { %>
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>অর্ডার ID</th>
            <th>মোট</th>
            <th>পেমেন্ট</th>
            <th>স্ট্যাটাস</th>
            <th>তারিখ</th>
            <th>বিস্তারিত</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
          <tr>
            <td><code><%= order.id.substring(0,8) %></code></td>
            <td>৳ <%= order.total %></td>
            <td><span class="badge badge-info"><%= order.paymentMethod %></span></td>
            <td>
              <span class="badge badge-<%= order.status === 'approved' ? 'success' : order.status === 'rejected' ? 'danger' : 'warning' %>">
                <%= order.status === 'approved' ? 'অ্যাপ্রুভড' : order.status === 'rejected' ? 'বাতিল' : 'অপেক্ষমান' %>
              </span>
            </td>
            <td><%= new Date(order.createdAt).toLocaleDateString('bn-BD') %></td>
            <td><a href="/dashboard/orders/<%= order.id %>" class="btn btn-sm btn-outline">দেখুন</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <a href="/dashboard/orders" class="btn btn-outline" style="margin-top:1rem;">সব অর্ডার দেখুন</a>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
