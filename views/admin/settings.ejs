<%- include('../partials/admin-header', { pageTitle: 'সেটিংস', activePage: 'settings' }) %>

<div class="admin-page-header">
  <h2 class="admin-page-title">সাইট সেটিংস</h2>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
<% } %>
<% if (success) { %>
  <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
<% } %>

<form method="POST" action="/admin/settings" enctype="multipart/form-data">
  <div class="admin-card">
    <h3><i class="fas fa-globe"></i> সাইটের তথ্য</h3>
    <div class="form-row-2">
      <div class="form-group">
        <label>সাইটের নাম</label>
        <input type="text" name="siteName" value="<%= settings.siteName %>" class="form-input">
      </div>
      <div class="form-group">
        <label>ট্যাগলাইন</label>
        <input type="text" name="siteTagline" value="<%= settings.siteTagline %>" class="form-input">
      </div>
    </div>
    <div class="form-row-2">
      <div class="form-group">
        <label>লোগো টেক্সট (ছবি না থাকলে)</label>
        <input type="text" name="logoText" value="<%= settings.logoText %>" class="form-input">
      </div>
      <div class="form-group">
        <label>লোগো ছবি আপলোড</label>
        <% if (settings.logoImage) { %>
          <div style="margin-bottom:0.5rem;"><img src="<%= settings.logoImage %>" style="max-height:50px;border-radius:6px;"></div>
        <% } %>
        <input type="file" name="logoImage" accept="image/*" class="form-input">
      </div>
    </div>
    <div class="form-group">
      <label>ফুটার টেক্সট</label>
      <input type="text" name="footerText" value="<%= settings.footerText %>" class="form-input">
    </div>
    <div class="form-row-2">
      <div class="form-group">
        <label>যোগাযোগ ইমেইল</label>
        <input type="email" name="contactEmail" value="<%= settings.contactEmail %>" class="form-input">
      </div>
      <div class="form-group">
        <label>যোগাযোগ ফোন</label>
        <input type="text" name="contactPhone" value="<%= settings.contactPhone %>" class="form-input">
      </div>
    </div>
  </div>

  <div class="admin-card" style="margin-top:1.5rem;">
    <h3><i class="fas fa-money-bill"></i> পেমেন্ট সেটিংস</h3>
    <div class="form-row-2">
      <div class="form-group">
        <label>বিকাশ নম্বর</label>
        <input type="text" name="bkashNumber" value="<%= settings.bkashNumber %>" placeholder="01XXXXXXXXX" class="form-input">
      </div>
      <div class="form-group">
        <label>বিকাশ নির্দেশনা</label>
        <input type="text" name="bkashInstructions" value="<%= settings.bkashInstructions %>" class="form-input">
      </div>
    </div>
    <div class="form-row-2">
      <div class="form-group">
        <label>নগদ নম্বর</label>
        <input type="text" name="nagadNumber" value="<%= settings.nagadNumber %>" placeholder="01XXXXXXXXX" class="form-input">
      </div>
      <div class="form-group">
        <label>নগদ নির্দেশনা</label>
        <input type="text" name="nagadInstructions" value="<%= settings.nagadInstructions %>" class="form-input">
      </div>
    </div>
    <div class="form-group">
      <label>রকেট নম্বর</label>
      <input type="text" name="rocketNumber" value="<%= settings.rocketNumber %>" placeholder="01XXXXXXXXX" class="form-input" style="max-width:300px;">
    </div>
  </div>

  <div class="form-actions" style="margin-top:1.5rem;">
    <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> সেটিংস সেভ করুন</button>
  </div>
</form>

<%- include('../partials/admin-footer') %>
