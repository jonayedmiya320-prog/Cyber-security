<%- include('../partials/admin-header', { pageTitle: 'প্রোডাক্ট এডিট', activePage: 'products' }) %>

<div class="admin-page-header">
  <h2 class="admin-page-title">প্রোডাক্ট এডিট করুন</h2>
  <a href="/admin/products" class="btn btn-outline"><i class="fas fa-arrow-left"></i> ফিরুন</a>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
<% } %>

<div class="admin-card">
  <form method="POST" action="/admin/products/edit/<%= product.id %>" enctype="multipart/form-data" class="admin-form">
    <div class="form-row-2">
      <div class="form-group">
        <label>প্রোডাক্টের নাম <span class="required">*</span></label>
        <input type="text" name="name" value="<%= product.name %>" required class="form-input">
      </div>
      <div class="form-group">
        <label>ক্যাটাগরি <span class="required">*</span></label>
        <select name="categoryId" required class="form-input">
          <option value="">বেছে নিন</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= product.categoryId === cat.id ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>বিবরণ</label>
      <textarea name="description" rows="5" class="form-input"><%= product.description %></textarea>
    </div>

    <div class="form-row-2">
      <div class="form-group">
        <label>দাম (৳) <span class="required">*</span></label>
        <input type="number" name="price" value="<%= product.price %>" step="1" min="0" required class="form-input">
      </div>
      <div class="form-group">
        <label>স্টক সংখ্যা</label>
        <input type="number" name="stock" value="<%= product.stock %>" min="0" class="form-input">
      </div>
    </div>

    <div class="form-group">
      <label>নতুন ছবি (বদলাতে চাইলে)</label>
      <% if (product.image) { %>
        <div style="margin-bottom:0.5rem;"><img src="<%= product.image %>" style="max-width:150px;border-radius:8px;"></div>
      <% } %>
      <input type="file" name="image" accept="image/*" class="form-input" onchange="previewImage(this)">
      <div id="imagePreview" style="margin-top:0.5rem;display:none;">
        <img id="previewImg" style="max-width:200px;border-radius:8px;">
      </div>
    </div>

    <div class="form-group">
      <label><i class="fas fa-file-upload"></i> প্রোডাক্ট ফাইল (বদলাতে চাইলে)</label>
      <% if (product.productFile) { %>
        <div class="alert alert-info" style="margin-bottom:0.5rem;">
          <i class="fas fa-file"></i> বর্তমান ফাইল: <strong><%= product.productFileName || 'আপলোড করা আছে' %></strong>
          <a href="/admin/download/<%= product.id %>" class="btn btn-sm btn-outline" style="margin-left:0.5rem;">
            <i class="fas fa-download"></i> দেখুন
          </a>
        </div>
      <% } %>
      <input type="file" name="productFile" class="form-input">
      <small class="form-hint">নতুন ফাইল দিলে পুরনোটা বদলে যাবে। সর্বোচ্চ ২০০MB।</small>
    </div>

    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="active" value="on" <%= product.active ? 'checked' : '' %>>
        <span>প্রোডাক্ট অ্যাক্টিভ রাখুন</span>
      </label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> আপডেট করুন</button>
      <a href="/admin/products" class="btn btn-outline btn-lg">বাতিল</a>
    </div>
  </form>
</div>

<%- include('../partials/admin-footer') %>