<%- include('../partials/admin-header', { pageTitle: 'লাইভ চ্যাট', activePage: 'chat' }) %>

<div class="admin-page-header">
  <h2 class="admin-page-title"><i class="fas fa-comments"></i> লাইভ চ্যাট সাপোর্ট</h2>
</div>

<div class="admin-chat-grid">
  <div class="admin-card chat-user-list">
    <h3>ইউজার তালিকা</h3>
    <div id="userList">
      <p style="color:#888; padding:1rem; text-align:center;">কোনো চ্যাট নেই</p>
    </div>
  </div>

  <div class="admin-card">
    <h3 id="chatTitle">বামে ইউজার বেছে নিন</h3>
    <div class="chat-messages" id="adminChatMessages">
      <div class="chat-welcome">
        <i class="fas fa-comments"></i>
        <p>কোনো ইউজার বেছে নিন</p>
      </div>
    </div>
    <div class="chat-input-area">
      <input type="text" id="adminChatInput" placeholder="বার্তা লিখুন..." class="chat-input" disabled>
      <button onclick="adminSendMessage()" class="btn btn-primary" id="sendBtn" disabled>
        <i class="fas fa-paper-plane"></i>
      </button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
let activeUserId = null;

socket.emit('joinRoom', { userId: 'admin-panel', userName: 'Admin', isAdmin: true });
socket.emit('getChats');

socket.on('allChats', (chats) => {
  const userList = document.getElementById('userList');
  userList.innerHTML = '';
  const entries = Object.entries(chats).filter(([id, msgs]) => msgs.length > 0);
  if (entries.length === 0) {
    userList.innerHTML = '<p style="color:#888; padding:1rem; text-align:center;">কোনো চ্যাট নেই</p>';
    return;
  }
  entries.forEach(([userId, messages]) => {
    const userName = messages.find(m => m.from === 'user')?.userName || 'Unknown';
    const lastMsg = messages[messages.length - 1];
    const div = document.createElement('div');
    div.className = 'chat-user-item' + (activeUserId === userId ? ' active' : '');
    div.id = 'user-' + userId;
    div.onclick = () => openChat(userId, userName, messages, div);
    div.innerHTML = `
      <div class="chat-user-name"><i class="fas fa-user"></i> ${userName}</div>
      <div class="chat-user-preview">${lastMsg.message.substring(0, 35)}...</div>
    `;
    userList.appendChild(div);
  });
});

socket.on('newUserMessage', ({ userId, userName, msg }) => {
  socket.emit('getChats');
  if (activeUserId === userId) {
    addMsg(msg);
  }
  document.title = '🔔 নতুন বার্তা!';
  setTimeout(() => { document.title = 'লাইভ চ্যাট - Admin'; }, 3000);
});

socket.on('messageSent', (msg) => {
  addMsg(msg);
});

function openChat(userId, userName, messages, el) {
  activeUserId = userId;
  document.getElementById('chatTitle').textContent = userName + ' এর চ্যাট';
  document.getElementById('adminChatInput').disabled = false;
  document.getElementById('sendBtn').disabled = false;

  const box = document.getElementById('adminChatMessages');
  box.innerHTML = '';
  messages.forEach(msg => addMsg(msg));

  document.querySelectorAll('.chat-user-item').forEach(e => e.classList.remove('active'));
  el.classList.add('active');
}

function addMsg(msg) {
  const welcome = document.querySelector('#adminChatMessages .chat-welcome');
  if (welcome) welcome.remove();

  const div = document.createElement('div');
  div.className = 'chat-msg ' + (msg.from === 'admin' ? 'chat-msg-user' : 'chat-msg-admin');
  div.innerHTML = `
    <div class="chat-bubble">
      <small><strong>${msg.userName}</strong></small>
      <p>${msg.message}</p>
      <span class="chat-time">${msg.time}</span>
    </div>
  `;
  const box = document.getElementById('adminChatMessages');
  box.appendChild(div);
  box.scrollTop = 99999;
}

function adminSendMessage() {
  if (!activeUserId) return;
  const input = document.getElementById('adminChatInput');
  const message = input.value.trim();
  if (!message) return;
  socket.emit('adminMessage', { userId: activeUserId, message });
  input.value = '';
}

document.getElementById('adminChatInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') adminSendMessage();
});
</script>

<%- include('../partials/admin-footer') %>