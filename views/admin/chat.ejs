<%- include('../partials/admin-header', { pageTitle: 'লাইভ চ্যাট', activePage: 'chat' }) %>

<div class="admin-page-header">
  <h2 class="admin-page-title"><i class="fas fa-comments"></i> লাইভ চ্যাট সাপোর্ট</h2>
</div>

<div class="admin-chat-grid">
  <!-- User List -->
  <div class="admin-card chat-user-list">
    <h3>ইউজার</h3>
    <div id="userList">
      <p class="text-muted" style="padding:1rem;">কোনো চ্যাট নেই</p>
    </div>
  </div>

  <!-- Chat Area -->
  <div class="admin-card chat-area-wrap">
    <h3 id="chatTitle">চ্যাট বেছে নিন</h3>
    <div class="chat-messages" id="chatMessages" style="height:400px; overflow-y:auto; padding:1rem; background:#f8f9fa; border-radius:8px; margin-bottom:1rem;">
    </div>
    <div class="chat-input-area">
      <input type="text" id="adminChatInput" placeholder="বার্তা লিখুন..." class="chat-input" disabled>
      <button onclick="adminSendMessage()" class="btn btn-primary" id="sendBtn" disabled>
        <i class="fas fa-paper-plane"></i>
      </button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
let activeUserId = null;
let activeUserName = null;

socket.emit('joinRoom', {
  userId: 'admin',
  userName: 'Admin',
  isAdmin: true
});

socket.emit('getChats');

socket.on('allChats', (chats) => {
  const userList = document.getElementById('userList');
  userList.innerHTML = '';
  if (Object.keys(chats).length === 0) {
    userList.innerHTML = '<p class="text-muted" style="padding:1rem;">কোনো চ্যাট নেই</p>';
    return;
  }
  Object.entries(chats).forEach(([userId, messages]) => {
    if (messages.length === 0) return;
    const userName = messages.find(m => m.from === 'user')?.userName || 'Unknown';
    const lastMsg = messages[messages.length - 1];
    const div = document.createElement('div');
    div.className = 'chat-user-item';
    div.onclick = () => openChat(userId, userName, messages);
    div.innerHTML = `
      <div class="chat-user-name"><i class="fas fa-user"></i> ${userName}</div>
      <div class="chat-user-preview">${lastMsg.message.substring(0, 30)}...</div>
    `;
    userList.appendChild(div);
  });
});

socket.on('newUserMessage', ({ userId, userName, msg }) => {
  socket.emit('getChats');
  if (activeUserId === userId) {
    addAdminMessage(msg);
  }
  // Notification
  document.title = '🔔 নতুন বার্তা - Admin';
  setTimeout(() => { document.title = 'লাইভ চ্যাট - Admin'; }, 3000);
});

function openChat(userId, userName, messages) {
  activeUserId = userId;
  activeUserName = userName;
  document.getElementById('chatTitle').textContent = userName + ' এর সাথে চ্যাট';
  document.getElementById('adminChatInput').disabled = false;
  document.getElementById('sendBtn').disabled = false;
  const chatMessages = document.getElementById('chatMessages');
  chatMessages.innerHTML = '';
  messages.forEach(msg => addAdminMessage(msg));

  document.querySelectorAll('.chat-user-item').forEach(el => el.classList.remove('active'));
  event.currentTarget.classList.add('active');
}

function addAdminMessage(msg) {
  const div = document.createElement('div');
  div.className = 'chat-msg ' + (msg.from === 'admin' ? 'chat-msg-user' : 'chat-msg-admin');
  div.innerHTML = `
    <div class="chat-bubble">
      <small><strong>${msg.userName}</strong></small>
      <p>${msg.message}</p>
      <span class="chat-time">${msg.time}</span>
    </div>
  `;
  document.getElementById('chatMessages').appendChild(div);
  document.getElementById('chatMessages').scrollTop = 99999;
}

function adminSendMessage() {
  if (!activeUserId) return;
  const input = document.getElementById('adminChatInput');
  const message = input.value.trim();
  if (!message) return;
  socket.emit('adminMessage', { userId: activeUserId, message });
  input.value = '';
}

document.getElementById('adminChatInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') adminSendMessage();
});
</script>

<%- include('../partials/admin-footer') %>