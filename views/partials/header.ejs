<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' : '' %><%= settings.siteName || 'MYMENSINGH CYBER LAB' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<nav class="navbar">
  <div class="container nav-inner">
    <a href="/" class="navbar-brand">
      <% if (settings.logoImage) { %>
        <img src="<%= settings.logoImage %>" alt="Logo" class="logo-img">
      <% } else { %>
        <span class="logo-text"><%= settings.logoText || 'MCL' %></span>
      <% } %>
      <span class="brand-name"><%= settings.siteName || 'MYMENSINGH CYBER LAB' %></span>
    </a>
    <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
    <ul class="nav-links" id="navLinks">
      <li><a href="/">হোম</a></li>
      <li><a href="/products">প্রোডাক্ট</a></li>
      <% if (user) { %>
        <li><a href="/cart"><i class="fas fa-shopping-cart"></i> কার্ট</a></li>
        <li><a href="/dashboard">ড্যাশবোর্ড</a></li>
        <% if (user.role === 'admin') { %>
          <li><a href="/admin" class="btn-admin">Admin</a></li>
        <% } %>
        <li><a href="/auth/logout" class="btn-logout">লগআউট</a></li>
      <% } else { %>
        <li><a href="/auth/login" class="btn-login">লগইন</a></li>
        <li><a href="/auth/register" class="btn-register">রেজিস্টার</a></li>
      <% } %>
    </ul>
  </div>
</nav>
<main class="main-content">