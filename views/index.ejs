  <div class="container">
    <div class="footer-cta-inner">
      <div class="footer-cta-left">
        <div class="footer-logo-big">
          <span class="logo-text">MCL</span>
          <div>
            <strong>MYMENSINGH CYBER LAB</strong>
            <p>Empowering the next generation of digital creators</p>
          </div>
        </div>
        <div class="footer-social">
          <a href="#"><i class="fab fa-facebook"></i></a>
          <a href="#"><i class="fab fa-youtube"></i></a>
          <a href="#"><i class="fab fa-telegram"></i></a>
          <a href="#"><i class="fab fa-github"></i></a>
        </div>
      </div>
      <div class="footer-cta-links">
        <div class="footer-link-group">
          <h4>Quick Links</h4>
          <a href="/">Home <i class="fas fa-arrow-right"></i></a>
          <a href="/products">Products <i class="fas fa-arrow-right"></i></a>
          <a href="/auth/register">Register <i class="fas fa-arrow-right"></i></a>
          <a href="/support">Support <i class="fas fa-arrow-right"></i></a>
