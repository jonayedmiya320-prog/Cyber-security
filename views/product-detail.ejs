<%- include('partials/header', { pageTitle: product.name }) %>

<section class="section">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">হোম</a> &rsaquo;
      <a href="/products">প্রোডাক্ট</a> &rsaquo;
      <span><%= product.name %></span>
    </div>

    <div class="product-detail-grid">
      <!-- Image -->
      <div class="product-detail-img-wrap">
        <% if (product.image) { %>
          <img src="<%= product.image %>" alt="<%= product.name %>" class="product-detail-img">
        <% } else { %>
          <div class="product-img-placeholder large"><i class="fas fa-cube"></i></div>
        <% } %>
      </div>

      <!-- Info -->
      <div class="product-detail-info">
        <% if (category) { %>
          <span class="product-category-badge"><%= category.name %></span>
        <% } %>
        <h1 class="product-detail-name"><%= product.name %></h1>
        <div class="product-detail-price">৳ <%= product.price %></div>

        <div class="product-stock-info">
          <% if (product.stock > 0) { %>
            <span class="stock-ok"><i class="fas fa-check-circle"></i> স্টকে আছে (<%= product.stock %>টি)</span>
          <% } else { %>
            <span class="stock-out"><i class="fas fa-times-circle"></i> স্টকে নেই</span>
          <% } %>
        </div>

        <div class="product-description">
          <h3>বিবরণ</h3>
          <p><%= product.description || 'কোনো বিবরণ নেই' %></p>
        </div>

        <% if (product.stock > 0) { %>
          <% if (user) { %>
            <form method="POST" action="/cart/add">
              <input type="hidden" name="productId" value="<%= product.id %>">
              <button type="submit" class="btn btn-primary btn-lg btn-block">
                <i class="fas fa-cart-plus"></i> কার্টে যোগ করুন
              </button>
            </form>
          <% } else { %>
            <a href="/auth/login" class="btn btn-primary btn-lg btn-block">
              <i class="fas fa-sign-in-alt"></i> কিনতে লগইন করুন
            </a>
          <% } %>
        <% } else { %>
          <button class="btn btn-disabled btn-lg btn-block" disabled>স্টকে নেই</button>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
