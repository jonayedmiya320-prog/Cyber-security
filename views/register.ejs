<%- include('partials/header', { pageTitle: 'রেজিস্টার' }) %>

<section class="auth-section">
  <div class="auth-card">
    <div class="auth-header">
      <h2><i class="fas fa-user-plus"></i> রেজিস্টার</h2>
      <p>নতুন অ্যাকাউন্ট তৈরি করুন</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %> <a href="/auth/login">লগইন করুন</a></div>
    <% } %>

    <form method="POST" action="/auth/register" class="auth-form">
      <div class="form-group">
        <label>পূর্ণ নাম</label>
        <input type="text" name="name" placeholder="আপনার নাম" required class="form-input">
      </div>
      <div class="form-group">
        <label>ইমেইল</label>
        <input type="email" name="email" placeholder="আপনার ইমেইল" required class="form-input">
      </div>
      <div class="form-group">
        <label>ফোন নম্বর</label>
        <input type="text" name="phone" placeholder="০১XXXXXXXXX" required class="form-input">
      </div>
      <div class="form-group">
        <label>পাসওয়ার্ড</label>
        <div class="input-eye-wrap">
          <input type="password" name="password" id="regPassword" placeholder="কমপক্ষে ৬ অক্ষর" required class="form-input">
          <button type="button" class="eye-btn" onclick="togglePassword('regPassword')"><i class="fas fa-eye"></i></button>
        </div>
      </div>
      <div class="form-group">
        <label>পাসওয়ার্ড নিশ্চিত করুন</label>
        <input type="password" name="confirm_password" placeholder="পুনরায় পাসওয়ার্ড দিন" required class="form-input">
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">অ্যাকাউন্ট তৈরি করুন</button>
    </form>

    <div class="auth-footer">
      <p>ইতিমধ্যে অ্যাকাউন্ট আছে? <a href="/auth/login">লগইন করুন</a></p>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
